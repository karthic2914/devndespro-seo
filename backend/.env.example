# PostgreSQL - Railway connection string
DATABASE_URL=postgresql://postgres:password@host.railway.app:5432/railway

# Google OAuth - from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# JWT Secret - generate a random string
JWT_SECRET=your-super-secret-jwt-key-change-this

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# SerpAPI — for Rank #1 SERP analysis (https://serpapi.com)
SERPAPI_KEY=your-serpapi-key-here

# Allowed Google emails (comma separated - leave empty to allow all)
ALLOWED_EMAILS=hello@devndespro.com,your-other-email@gmail.com

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Backend URL (used for OAuth callbacks in production)
BACKEND_URL=http://localhost:4000

# Optional explicit callback URI for GSC OAuth (recommended in production)
GSC_REDIRECT_URI=http://localhost:4000/api/auth/gsc/callback

# Port
PORT=4000
